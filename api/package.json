{
  "name": "ds-psi-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "loader.cjs",
  "scripts": {
    "dev": "prisma generate && tsx watch src/server.ts",
    "build": "tsc",
    "start": "node loader.cjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.3.0",
    "@prisma/client": "^6.3.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "nodemailer": "^9.0.3",
    "prisma": "^6.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "postinstall": "prisma generate"
}
