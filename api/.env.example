# API environment — copy to api/.env (local dev)
# NEVER commit api/.env or upload your local copy to production.

# --- Local development ---
DATABASE_URL="mysql://user:password@localhost:3306/ds_psi"
JWT_SECRET="change-this-to-a-long-random-string"
FRONTEND_URL="http://localhost:5173"
PORT=3001

# --- Production (server ~/api.danielasantos.work/.env) ---
# DATABASE_URL="mysql://dmolnlpq_dspsi:PASSWORD@localhost:3306/dmolnlpq_dspsi"
# JWT_SECRET="long-random-production-secret"
# FRONTEND_URL="https://danielasantos.work"
# NODE_ENV=production
# PORT is set by Passenger — omit on server

# Seed defaults (only when running npm run db:seed)
ADMIN_EMAIL="admin@danielasantos.work"
ADMIN_PASSWORD="ChangeMeAdmin123!"

# Email notifications (optional — therapist alert when a patient submits a form)
# Namecheap / cPanel — use a mailbox created under Email Accounts
#
# Option A — SSL (recommended):
# SMTP_HOST="mail.danielasantos.work"
# SMTP_PORT=465
# SMTP_SECURE=true
#
# Option B — STARTTLS:
# SMTP_HOST="mail.danielasantos.work"
# SMTP_PORT=587
# SMTP_SECURE=false
#
# SMTP_USER="noreply@danielasantos.work"
# SMTP_PASS="your-mailbox-password"
# SMTP_FROM="noreply@danielasantos.work"
