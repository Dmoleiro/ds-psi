generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  therapist
  coordinator
}

enum SessionStatus {
  active
  in_progress
  completed
  revoked
}

enum FormStatus {
  not_started
  in_progress
  submitted
}

enum AttendanceStatus {
  present_unpaid
  present_paid
  absent
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         UserRole
  passwordHash String    @map("password_hash")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  patients       Patient[]
  intakeSessions IntakeSession[]
  attendanceRecords AttendanceRecord[]

  @@map("users")
}

model Patient {
  id            String    @id @default(uuid())
  therapistId   String    @map("therapist_id")
  locationId    String    @map("location_id")
  fullName      String    @map("full_name")
  email         String?
  phone         String?
  birthDate     DateTime? @map("birth_date") @db.Date
  internalNotes String?   @map("internal_notes") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  therapist         User              @relation(fields: [therapistId], references: [id])
  location          Location          @relation(fields: [locationId], references: [id])
  intakeSessions    IntakeSession[]
  attendanceRecords AttendanceRecord[]

  @@index([therapistId])
  @@index([locationId])
  @@map("patients")
}

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patients Patient[]

  @@map("locations")
}

model AttendanceRecord {
  id          String           @id @default(uuid())
  patientId   String           @map("patient_id")
  therapistId String           @map("therapist_id")
  sessionDate DateTime         @map("session_date") @db.Date
  status      AttendanceStatus
  notes       String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User    @relation(fields: [therapistId], references: [id])

  @@unique([patientId, sessionDate])
  @@index([therapistId, sessionDate])
  @@map("attendance_records")
}

model IntakeSession {
  id          String        @id @default(uuid())
  patientId   String        @map("patient_id")
  therapistId String        @map("therapist_id")
  tokenHash   String        @unique @map("token_hash")
  status      SessionStatus @default(active)
  expiresAt   DateTime?     @map("expires_at")
  completedAt DateTime?     @map("completed_at")
  consentAt   DateTime?     @map("consent_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  patient  Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User         @relation(fields: [therapistId], references: [id])
  forms    SessionForm[]

  @@index([therapistId])
  @@index([patientId])
  @@map("intake_sessions")
}

model FormDefinition {
  id          String  @id
  title       String
  version     Int     @default(1)
  schemaJson  Json?   @map("schema_json")
  active      Boolean @default(true)
  description String? @db.Text

  sessionForms SessionForm[]

  @@map("form_definitions")
}

model SessionForm {
  id        String     @id @default(uuid())
  sessionId String     @map("session_id")
  formId    String     @map("form_id")
  status    FormStatus @default(not_started)
  sortOrder Int        @map("sort_order")

  session    IntakeSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  definition FormDefinition  @relation(fields: [formId], references: [id])
  draft      FormDraft?
  submission FormSubmission?

  @@unique([sessionId, formId])
  @@index([sessionId])
  @@map("session_forms")
}

model FormDraft {
  sessionFormId String   @id @map("session_form_id")
  answersJson   Json     @map("answers_json")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessionForm SessionForm @relation(fields: [sessionFormId], references: [id], onDelete: Cascade)

  @@map("form_drafts")
}

model FormSubmission {
  sessionFormId String   @id @map("session_form_id")
  answersJson   Json     @map("answers_json")
  submittedAt   DateTime @default(now()) @map("submitted_at")
  ip            String?

  sessionForm SessionForm @relation(fields: [sessionFormId], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}
